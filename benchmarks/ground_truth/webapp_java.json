{
  "01_find_callers": {
    "description": "Who calls validateToken?",
    "query": "refs validateToken --kind calls",
    "expected": [
      {
        "source": "authenticate",
        "file": "middleware/AuthMiddleware.java"
      },
      {
        "source": "getCurrentUser",
        "file": "auth/AuthService.java"
      },
      {
        "source": "refreshToken",
        "file": "auth/TokenService.java"
      }
    ]
  },
  "02_file_structure": {
    "description": "What's in auth/TokenService.java?",
    "query": "outline auth/TokenService.java",
    "expected": [
      {
        "name": "log",
        "kind": "variable"
      },
      {
        "name": "TOKEN_EXPIRY",
        "kind": "variable"
      },
      {
        "name": "TokenService",
        "kind": "class"
      },
      {
        "name": "generateToken",
        "kind": "method"
      },
      {
        "name": "validateToken",
        "kind": "method"
      },
      {
        "name": "refreshToken",
        "kind": "method"
      },
      {
        "name": "revokeToken",
        "kind": "method"
      },
      {
        "name": "extractToken",
        "kind": "method"
      }
    ]
  },
  "03_refactor_impact": {
    "description": "Impact of changing AuthService",
    "query": "impact AuthService --depth 3",
    "expected_refs": [
