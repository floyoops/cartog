      },
      {
        "source": "refreshToken",
        "file": "auth/TokenService.java",
        "kind": "raises"
      },
      {
        "source": "revokeToken",
        "file": "auth/TokenService.java",
        "kind": "raises"
      },
      {
        "source": "ExpiredTokenException",
        "file": "errors/ExpiredTokenException.java",
        "kind": "inherits"
      }
    ]
  },
