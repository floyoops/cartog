      "services/AuthenticationService.java",
      "routes/AuthRoutes.java",
      "api/v1/AuthController.java",
      "api/v2/AuthController.java",
      "Main.java"
    ]
  },
  "04_class_hierarchy": {
    "description": "Hierarchy of AppException",
    "query": "hierarchy AppException",
    "expected": [
      {
        "name": "ValidationException"
      },
      {
        "name": "TokenException"
      },
      {
        "name": "AuthenticationException"
      },
      {
        "name": "PaymentException"
      }
    ]
  },
  "05_trace_call_chain": {
    "description": "Trace handleLogin call chain",
    "query_sequence": [
      "callees handleLogin",
      "callees authenticate",
      "callees login",
      "callees generateToken",
      "callees executeQuery",
      "callees getConnection"
    ],
    "expected_chain": [
      {
        "caller": "handleLogin",
        "callee": "UserValidator.validateLogin"
      },
      {
        "caller": "handleLogin",
        "callee": "routes.handleLogin"
      },
      {
        "caller": "authenticate",
        "callee": "authService.login"
      },
      {
        "caller": "authenticate",
        "callee": "db.insert"
      },
      {
        "caller": "login",
        "callee": "tokenService.generateToken"
      },
      {
        "caller": "generateToken",
        "callee": "String.format"
      },
      {
        "caller": "executeQuery",
        "callee": "pool.getConnection"
      },
      {
        "caller": "executeQuery",
        "callee": "pool.releaseConnection"
      },
      {
        "caller": "getConnection",
        "callee": "conn.setInUse"
      }
    ]
  },
  "06_file_deps": {
    "description": "What does routes/AuthRoutes.java import?",
    "query": "deps routes/AuthRoutes.java",
    "expected": [
      "DatabaseConnection",
      "AuthenticationException",
      "TokenException",
      "AuthenticationService",
      "Logger"
    ]
  },
  "07_type_references": {
    "description": "Type references to TokenException",
    "query": "refs TokenException",
