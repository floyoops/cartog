{
  "name": "cartog",
  "description": "Code graph navigation and semantic search for LLM coding agents",
  "version": "0.11.0",
  "license": "MIT",
  "keywords": ["code-graph", "tree-sitter", "semantic-search", "code-navigation", "refactoring"],
  "author": {
    "name": "Julien Rollin"
  },
  "skills": "./skills/",
  "mcpServers": {
    "cartog": {
      "command": "cartog",
      "args": ["serve", "--watch"]
    }
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash skills/cartog/scripts/ensure_indexed.sh"
          }
        ]
      }
    ]
  }
}
